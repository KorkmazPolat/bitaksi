# Anthropic API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LLM Configuration
LLM_MODEL=claude-sonnet-4-6
VISION_MODEL=claude-sonnet-4-6
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Vector Store
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_RAW=hr_docs_raw
CHROMA_COLLECTION_RELATIVES=hr_docs_relatives

# Retrieval Settings
TOP_K=5
SIMILARITY_THRESHOLD=0.6
FALLBACK_TOP_K=8

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# Evaluation
EVAL_RECALL_K=5
